# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# JWT Configuration
JWT_SECRET=your-strong-random-secret-key

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Admin Emails - Comma separated list
# Users with these emails will automatically become admins upon first login
# Add more emails by separating with commas (no spaces around commas)
# Example: ADMIN_EMAILS=admin1@gmail.com,admin2@gmail.com,admin3@gmail.com
ADMIN_EMAILS=shyampickyourhire@gmail.com
